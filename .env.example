# Core
NEXT_PUBLIC_APP_URL=https://enchere.cm
NEXT_PUBLIC_SUPPORT_WHATSAPP=237600000000
BACKEND_PORT=4000

# PostgreSQL, recommended providers: Neon, Supabase, Railway, AWS RDS, Crunchy Bridge
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/enchere_cm?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/enchere_cm?sslmode=require

# Object storage, S3-compatible. Cloudflare R2 or AWS S3 are both valid.
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=enchere-cm-documents
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

# Realtime bidding provider, recommended external managed service.
REALTIME_PROVIDER=ably
REALTIME_API_KEY=change-me

# Payments
ORANGE_MONEY_CLIENT_ID=change-me
ORANGE_MONEY_CLIENT_SECRET=change-me
ORANGE_MONEY_WEBHOOK_SECRET=change-me
MTN_MOMO_SUBSCRIPTION_KEY=change-me
MTN_MOMO_API_USER=change-me
MTN_MOMO_API_KEY=change-me
MTN_MOMO_WEBHOOK_SECRET=change-me

# Notifications
EMAIL_PROVIDER=resend
RESEND_API_KEY=change-me
SMS_PROVIDER=termii-or-local-aggregator
SMS_API_KEY=change-me
WHATSAPP_PROVIDER=meta-or-local-aggregator
WHATSAPP_ACCESS_TOKEN=change-me

# Admin security
ADMIN_2FA_ISSUER=Enchere.cm
SESSION_SECRET=generate-a-long-random-value
