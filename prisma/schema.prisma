generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  moderator
  verification_agent
  customer_support
  finance
  seller
  buyer
}

enum VerificationStatus {
  pending
  verified
  rejected
  suspended
}

enum SellerType {
  individual
  company
  professional
}

enum AuctionStatus {
  draft
  pending_review
  live
  closed
  cancelled
}

enum PaymentProvider {
  orange_money
  mtn_momo
  card
  bank_transfer
  manual_admin
}

enum PaymentPurpose {
  deposit
  winning_payment
  refund
  seller_payout
}

enum PaymentStatus {
  pending
  authorized
  captured
  escrowed
  released
  refunded
  failed
}

enum DisputeStatus {
  open
  in_review
  resolved
  rejected
}

enum DisputePriority {
  low
  medium
  high
}

enum NotificationChannel {
  email
  sms
  whatsapp
  in_app
}

enum NotificationStatus {
  queued
  sent
  failed
}

enum DocumentStatus {
  pending
  valid
  rejected
  expired
}

model User {
  id             String             @id @default(cuid())
  fullName       String
  email          String             @unique
  phone          String             @unique
  passwordHash   String?
  role           UserRole
  city           String
  emailVerified  Boolean            @default(false)
  phoneVerified  Boolean            @default(false)
  identityStatus VerificationStatus @default(pending)
  suspended      Boolean            @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  sellerProfile SellerProfile?
  buyerProfile  BuyerProfile?
  documents     VerificationDocument[]
  disputes      Dispute[]            @relation("DisputeOpenedBy")
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([role])
  @@index([identityStatus])
  @@index([city])
}

model SellerProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  displayName        String
  type               SellerType
  verificationStatus VerificationStatus @default(pending)
  trustBadges        String[]           @default([])
  documentsRequested String[]           @default([])
  payoutAccount      String?
  commissionRate     Decimal            @default(0.075) @db.Decimal(5, 4)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  auctions Auction[]
  payments Payment[]

  @@index([verificationStatus])
  @@index([type])
}

model BuyerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  walletBalance   Decimal  @default(0) @db.Decimal(14, 2)
  blockedDeposits Decimal  @default(0) @db.Decimal(14, 2)
  activeBids      Int      @default(0)
  disputesCount   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bids     Bid[]
  payments Payment[]

  @@index([activeBids])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  riskLevel String    @default("standard")
  enabled   Boolean   @default(true)
  auctions  Auction[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  region    String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Auction {
  id               String        @id @default(cuid())
  sellerId         String
  categoryId       String?
  title            String
  description      String?
  category         String
  city             String
  startPrice       Decimal       @db.Decimal(14, 2)
  currentPrice     Decimal       @db.Decimal(14, 2)
  minimumIncrement Decimal       @db.Decimal(14, 2)
  reservePrice     Decimal       @db.Decimal(14, 2)
  buyNowPrice      Decimal?      @db.Decimal(14, 2)
  status           AuctionStatus @default(pending_review)
  inspected        Boolean       @default(false)
  documentValid    Boolean       @default(false)
  deliveryMode     String?
  endsAt           DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  seller    SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  categoryRef Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bids      Bid[]
  payments  Payment[]
  disputes  Dispute[]
  documents VerificationDocument[]

  @@index([status])
  @@index([category])
  @@index([city])
  @@index([endsAt])
  @@index([sellerId])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  buyerId   String
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  auction Auction      @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Restrict)

  @@index([auctionId, createdAt])
  @@index([buyerId])
}

model Payment {
  id                String          @id @default(cuid())
  buyerId           String
  sellerId          String?
  auctionId         String?
  provider          PaymentProvider
  purpose           PaymentPurpose
  amount            Decimal         @db.Decimal(14, 2)
  status            PaymentStatus   @default(pending)
  externalReference String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  buyer   BuyerProfile   @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  seller  SellerProfile? @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  auction Auction?       @relation(fields: [auctionId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([purpose])
  @@index([provider])
  @@index([auctionId])
  @@index([buyerId])
}

model Dispute {
  id             String          @id @default(cuid())
  auctionId      String
  openedByUserId String
  reason         String
  status         DisputeStatus   @default(open)
  priority       DisputePriority @default(medium)
  resolutionNote String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  auction      Auction @relation(fields: [auctionId], references: [id], onDelete: Restrict)
  openedByUser User    @relation("DisputeOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([priority])
  @@index([auctionId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  subject   String
  body      String
  status    NotificationStatus  @default(queued)
  createdAt DateTime            @default(now())
  sentAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channel])
  @@index([status])
}

model VerificationDocument {
  id        String         @id @default(cuid())
  userId    String?
  auctionId String?
  type      String
  fileKey   String
  status    DocumentStatus @default(pending)
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction? @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([auctionId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}
